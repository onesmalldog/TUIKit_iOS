        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "服务器开小差啦，请稍后重试"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "伺服器開小差啦，請稍後重試"
          }
