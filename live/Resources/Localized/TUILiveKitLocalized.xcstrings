    "common_disconnect_guest_tips": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Are you sure you want to disconnect xxx?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "确定要断开xxx的连麦吗？"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "確定要斷開xxx的連麥嗎？"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "xxxの接続を切断したいですか？"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "هل أنت متأكد أنك تريد قطع الاتصال بـ xxx؟"
