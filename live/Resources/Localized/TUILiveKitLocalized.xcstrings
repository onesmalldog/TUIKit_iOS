    "common_client_error_already_in_other_room": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "User is Already in Another Room, Single RoomEngine Instance Only Supports User Entering One Room, To Enter Different Room, Please Leave the Room or Use New RoomEngine Instance"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当前用户已在别的房间内，单个 roomEngine 实例只支持用户进入一个房间，如果要进入不同的房间请先退房或者使用新的 roomEngine 实例"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "當前用戶已在別的房間內，單個 roomEngine 實例只支持用戶進入一個房間，如果要進入不同的房間請先退房或者使用新的 roomEngine 實例"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "現在のユーザーは別の部屋にいます。単一のルームエンジンインスタンスは、ユーザーのみが1つの部屋に入るのをサポートします。別の部屋に入りたい場合は、最初にチェックアウトするか、新しいルームエンジンインスタンスを使用してください。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "المستخدم موجود بالفعل في غرفة أخرى"
          }
        }
      }
    },
    "common_client_error_camera_device_empty": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No Camera Device Currently, Please Insert Camera Device to Solve the Problem"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当前无摄像头设备，请插入摄像头设备解决该问题"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "當前無攝像頭設備，請插入攝像頭設備解決該問題"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "現在、カメラデバイスはありません。カメラデバイスを挿入して問題を解決してください"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا يوجد جهاز كاميرا حالياً، يرجى إدخال جهاز كاميرا"
          }
        }
      }
    },
    "common_client_error_camera_not_authorized": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Camera has No System Authorization, Check System Authorization"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "摄像头没有系统授权, 检查系统授权"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "攝像頭沒有系統授權, 檢查系統授權"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "カメラにはシステム承認がありません。システム認証を確認してください"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الكاميرا ليس لديها إذن النظام، تحقق من إذن النظام"
          }
        }
      }
    },
    "common_client_error_camera_occupied": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Camera is Occupied, Check if Other Process is Using Camera"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "摄像头被占用，检查是否有其他进程使用摄像头"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "攝像頭被佔用，檢查是否有其他進程使用攝像頭"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "カメラが占有されています。カメラを使用して他のプロセスがあるかどうかを確認してください"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الكاميرا مشغولة، تحقق مما إذا كانت عملية أخرى تستخدم الكاميرا"
          }
        }
      }
    },
    "common_client_error_camera_start_fail": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "System Issue, Failed to Open Camera. Check if Camera Device is Normal"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "系统问题，打开摄像头失败。检查摄像头设备是否正常"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "系統問題，打開攝像頭失敗。檢查攝像頭設備是否正常"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "システムの問題は、カメラをオンにすることができませんでした。カメラデバイスが正常かどうかを確認してください"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "مشكلة في النظام، فشل فتح الكاميرا. تحقق مما إذا كان جهاز الكاميرا طبيعياً"
          }
        }
      }
    },
    "common_client_error_connection_connecting": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The room you are invited to connect to is already in the invitation list or is already connected."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "被邀请连线的房间已在邀请列表或者已连线。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "被邀請連線的房間已在邀請列表或者已連線。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "接続するために招待されている部屋は、すでに招待リストに載っているか、接続されています。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الغرفة المدعو للاتصال بها موجودة بالفعل في قائمة الدعوات أو متصلة بالفعل."
          }
        }
      }
    },
    "common_client_error_exit_not_supported_for_room_owner": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Room Owner Does Not Support Leaving the Room, Room Owner Can Only Close the Room"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "房主不支持退房操作，房主只能解散房间"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "房主不支持退房操作，房主只能解散房間"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "住宅所有者はチェックアウト操作をサポートしていません、住宅所有者は部屋を解散することしかできません"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "صاحب الغرفة لا يدعم مغادرة الغرفة، يمكنه فقط إغلاق الغرفة"
          }
        }
      }
    },
    "common_client_error_failed": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Server is having a hiccup, please try again later"
