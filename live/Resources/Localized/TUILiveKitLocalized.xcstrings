    "common_anchor_end_link_tips": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You are currently co-guesting with other streamers. Would you like to [End Live] ?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当前处于连麦状态，是否需要「关闭直播间」"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "當前處於連麥狀態，是否需要「關閉直播間」"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "現在、接続されている州では、「ライブブロードキャストルームを閉じる」必要がありますか？"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أنت حالياً في بث مشترك مع مذيعين آخرين. هل تريد [إنهاء البث]؟"
          }
        }
      }
    },
    "common_battle_connecting": {
