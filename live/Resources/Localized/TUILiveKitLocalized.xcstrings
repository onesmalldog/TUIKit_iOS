    "common_host_kick_user_after_connect": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The connection is successful. Users beyond the first 6 seats have been removed."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "连线成功。前 6 个麦位以外的用户已被移除。如需互动，请重新邀请。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "連線成功。前 6 個麥位以外的使用者已被移除。如需互動，請重新邀請。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "接続に成功しました。先着6席以外のユーザーはマイクを降りました。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تم الاتصال بنجاح. تمت إزالة المستخدمين خارج أول 6 مقاعد."
          }
        }
      }
    },
    "common_audience_kicked_re_apply": {
      "extractionState": "manual",
