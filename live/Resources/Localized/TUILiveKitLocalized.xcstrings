    "common_end_connection_tips": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You are currently co-hosting with other streamers. Would you like to [End Co-host] or [End Live] ?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当前处于连线状态，是否需要「断开连线」或「关闭直播间」"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "當前處於連線狀態，是否需要「斷開連線」或「關閉直播間」"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "現在、接続されている州では、「ライブブロードキャストルームを閉じる」または「閉じる」必要がありますか？"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أنت حالياً في بث مشترك. هل تريد [إنهاء البث المشترك] أم [إنهاء البث]؟"
          }
        }
      }
    },
