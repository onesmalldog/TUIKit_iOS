    "common_battle_end_pk": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "End PK"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "结束PK"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "結束PK"
          }
        },
        "ja": {
          "stringUnit": {
