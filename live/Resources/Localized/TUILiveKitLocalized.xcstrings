    "common_audience_end_link_tips": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You are currently co-guesting with other streamers. Would you like to [End Co-guest] or [Exit Live] ?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当前处于连麦状态，是否需要「断开连麦」或「退出直播间」"
          }
        },
        "zh-Hant": {
          "stringUnit": {
