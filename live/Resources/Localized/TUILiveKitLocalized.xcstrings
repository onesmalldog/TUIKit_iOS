            "value": "PKを終了します"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "إنهاء المنافسة"
          }
        }
      }
    },
    "common_battle_end_pk_tips": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Are you sure you want to end the battle? The current result will be the final result after the end"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "确定要结束PK吗？结束后将以当前结果为最终结果"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "確定要結束PK嗎？結束後將以當前結果為最終結果"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "PKを終了したいですか？終了後、現在の結果が最終結果になります"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "هل أنت متأكد أنك تريد إنهاء المنافسة؟ النتيجة الحالية ستكون النتيجة النهائية"
          }
        }
      }
    },
