platform :ios, '14.0'
source 'https://cdn.cocoapods.org/'

# ── Unified TXLiteAVSDK version ──
TXLITEAVSDK_VERSION = '13.2.20652'

# ── Shared dependency definition ──
def shared_pods
  use_frameworks!

  # ── Third-party open source libraries ──
  pod 'Alamofire', '5.0.0'
  pod 'SnapKit', '5.0.1'
  pod 'Kingfisher', '6.3.1'
  pod 'Toast-Swift'

  # ── Shell project local pods ──
  pod 'Login',       :path => 'login/Login.podspec'
  pod 'AppAssembly', :path => 'assembly/AppAssembly.podspec'

  # Remote SDK
  pod 'TXLiteAVSDK_Professional', TXLITEAVSDK_VERSION
  pod 'TUICore'

  pod 'MJRefresh', '3.7.5'

end

target 'RTCubeLab' do
  shared_pods

  # Screen-sharing broadcast extension Podfile config
  target 'RTCubeLabReplayExtension' do
    inherit! :search_paths
    pod 'TXLiteAVSDK_Professional/ReplayKitExt', TXLITEAVSDK_VERSION
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '14.0'
      config.build_settings['CODE_SIGNING_ALLOWED'] = 'NO'
    end
  end
end
